    {
      "name": "Get Member Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Validate user profile response fields\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.exist;\r",
              "    pm.expect(jsonData.fullName).to.exist;\r",
              "    pm.expect(jsonData.username).to.exist;\r",
              "    pm.expect(jsonData.email).to.exist;\r",
              "    pm.expect(jsonData.avatarUrl).to.exist;\r",
              "});\r",
              "pm.test(\"Response time is less than 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
